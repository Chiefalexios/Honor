<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.HonorGuard" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.HonorGuard.InCall" parent="Theme.HonorGuard">
        <item name="android:windowShowWhenLocked">true</item>
        <item name="android:windowTurnScreenOn">true</item>
        <item name="android:windowKeepScreenOn">true</item>
        <item name="android:windowDismissKeyguard">true</item>
    </style>
</resources>
